### Example environment variables for local development
# Copy this file to `.env.local` and fill in your real keys (DO NOT commit `.env.local`).

# Alpaca (equities)
ALPACA_LIVE_API_KEY=your_alpaca_key_here
ALPACA_LIVE_API_SECRET=your_alpaca_secret_here

# Gemini (crypto)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_SECRET=your_gemini_secret_here

# Binance (optional)
BINANCE_LIVE_API_KEY=your_binance_key_here
\
# AngelOne (SmartAPI) - used for NSE trading (paper or live)
# Copy these into your local `.env.local` if you want the server to auto-use AngelOne creds.
ANGEL_API_KEY=your_angel_api_key_here
ANGEL_CLIENT_CODE=your_client_code_here
ANGEL_MPIN=your_mpin_here
ANGEL_TOTP_SEED=YOUR_BASE32_TOTP_SEED_HERE

# Optional AngelOne controls
ANGEL_API_BASE=https://apiconnect.angelone.in
ANGEL_USE_SERVER_CREDS=false
ANGEL_ENV=paper
